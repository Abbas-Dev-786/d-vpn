PORT=3001
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

ZAMA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
RELAYER_PRIVATE_KEY=0x...
DVPN_CONTRACT_ADDRESS=0x...

FLOW_EVM_RPC_URL=https://testnet.evm.nodes.onflow.org
FLOW_EVM_CHAIN_ID=545
FLOW_SETTLER_PRIVATE_KEY=0x...
FLOW_TREASURY_ADDRESS=0x...

FLOW_CADENCE_ACCESS_NODE=access.devnet.nodes.onflow.org:9000
FLOW_CADENCE_NETWORK=testnet
FLOW_SCHEDULER_ADDRESS=0x...
FLOW_SCHEDULER_PRIVATE_KEY=0x...
FLOW_SCHEDULER_KEY_INDEX=0

# Optional overrides (Flow testnet defaults shown in runtime.ts)
# FLOW_CRON_ADDRESS=0x5cbfdec870ee216d
# FLOW_CRON_UTILS_ADDRESS=0x5cbfdec870ee216d
# FLOW_TRANSACTION_SCHEDULER_ADDRESS=0x8c5303eaa26202d6
# FLOW_TRANSACTION_SCHEDULER_UTILS_ADDRESS=0x8c5303eaa26202d6
# FLOW_TOKEN_ADDRESS=0x7e60df042a9c0868
# FUNGIBLE_TOKEN_ADDRESS=0x9a0766d93b6608b7
# FLOW_EVM_CADENCE_ADDRESS=0x8c5303eaa26202d6

CUSTODIAL_KEY_ENCRYPTION_SECRET=replace_with_32_plus_characters

# Optional tuning
FLOW_RATE_PER_SECOND=0.00001
FLOW_MAX_PAYOUT_PER_SESSION=0.05
FLOW_CRON_EXECUTOR_PRIORITY=1
FLOW_CRON_EXECUTOR_EFFORT=1000
FLOW_CRON_KEEPER_EFFORT=2500
FLOW_CRON_CALL_GAS_LIMIT=100000
