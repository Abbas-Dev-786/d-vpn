{
  "name": "api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check:no-mocks": "if rg -n \"mock|simulate|0xMOCK|Math\\.random\" src/routes src/lib src/config; then echo 'Mock/simulated patterns found in runtime backend code'; exit 1; fi",
    "push": "drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "drizzle-kit push --force --config ./drizzle.config.ts"
  },
  "dependencies": {
    "@onflow/fcl": "^1.21.10",
    "@types/pg": "^8.20.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "ethers": "^6.16.0",
    "express": "^5",
    "pg": "^8.20.0",
    "pino": "^9",
    "pino-http": "^10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "typescript": "^5.9.3"
  }
}
